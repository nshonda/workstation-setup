{
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "openbrowser-ai": {
      "source": {
        "source": "github",
        "repo": "billy-enrizky/openbrowser-ai"
      }
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "ToolSearch",
      "mcp__context7__*",
      "mcp__jira-basis__*",
      "mcp__redmine-onerhino__*",
      "mcp__plugin_github_github__*",
      "mcp__plugin_openbrowser_openbrowser__*",
      "mcp__supabase__*",
      "mcp__slack-basis__slack_read_channel",
      "mcp__slack-basis__slack_read_thread",
      "mcp__slack-basis__slack_read_canvas",
      "mcp__slack-basis__slack_read_user_profile",
      "mcp__slack-basis__slack_search_channels",
      "mcp__slack-basis__slack_search_public",
      "mcp__slack-basis__slack_search_public_and_private",
      "mcp__slack-basis__slack_search_users",
      "mcp__slack-basis__slack_send_message_draft",
      "mcp__slack-basis__slack_schedule_message",
      "mcp__slack-onerhino__slack_read_channel",
      "mcp__slack-onerhino__slack_read_thread",
      "mcp__slack-onerhino__slack_read_canvas",
      "mcp__slack-onerhino__slack_read_user_profile",
      "mcp__slack-onerhino__slack_search_channels",
      "mcp__slack-onerhino__slack_search_public",
      "mcp__slack-onerhino__slack_search_public_and_private",
      "mcp__slack-onerhino__slack_search_users",
      "mcp__slack-onerhino__slack_send_message_draft",
      "mcp__slack-onerhino__slack_schedule_message",
      "mcp__gdocs-projects__*",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git tag:*)",
      "Bash(git rev-parse:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(git shortlog:*)",
      "Bash(git describe:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(uname:*)",
      "Bash(hostname:*)",
      "Bash(date:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(node --version:*)",
      "Bash(npm --version:*)",
      "Bash(npm list:*)",
      "Bash(npm ls:*)",
      "Bash(python --version:*)",
      "Bash(python3 --version:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(rtk gain:*)",
      "Bash(rtk discover:*)",
      "Bash(rtk --version:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/strip-co-authored-by.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_github_github__*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/strip-attribution-mcp.sh"
          }
        ]
      },
      {
        "matcher": "mcp__slack-basis__slack_send_message",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/slack-schedule-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "mcp__slack-onerhino__slack_send_message",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/slack-schedule-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "mcp__jira-basis__jira_update_issue",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/validate-mcp-inputs.sh"
          }
        ]
      },
      {
        "matcher": "mcp__jira-basis__jira_transition_issue",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/validate-mcp-inputs.sh"
          }
        ]
      },
      {
        "matcher": "mcp__jira-basis__jira_add_comment",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/validate-mcp-inputs.sh"
          }
        ]
      },
      {
        "matcher": "mcp__jira-basis__jira_add_worklog",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/validate-mcp-inputs.sh"
          }
        ]
      },
      {
        "matcher": "mcp__redmine-onerhino__redmine_request",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/validate-mcp-inputs.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/cross-project-memory.js"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "openbrowser@openbrowser-ai": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  }
}
