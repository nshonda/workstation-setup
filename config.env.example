# Workstation Setup Configuration
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
#
# Required values are marked [REQUIRED]. Everything else is optional —
# leave blank or commented out to skip.

# ──────────────────────────────────────────────
# Identity [REQUIRED]
# ──────────────────────────────────────────────

WS_FULL_NAME="Your Name"
WS_PERSONAL_EMAIL="you@example.com"
WS_WORK_EMAIL="you@company.com"
WS_PERSONAL_GH_USER="your-github-username"
WS_WORK_GH_USER="your-work-github-username"

# ──────────────────────────────────────────────
# GitHub Tokens [REQUIRED]
# ──────────────────────────────────────────────
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, read:org, read:user
# Create one token per account (log into each account separately).
# Stored in system keychain on first run.

GH_PERSONAL_TOKEN=""
GH_WORK_TOKEN=""

# ──────────────────────────────────────────────
# Jira (Atlassian)
# ──────────────────────────────────────────────
# URL format: company.atlassian.net (no https://, no trailing slash)
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
# Leave JIRA_URL blank to skip Jira setup entirely.

JIRA_URL=""
JIRA_EMAIL=""
JIRA_TOKEN=""

# ──────────────────────────────────────────────
# Redmine
# ──────────────────────────────────────────────
# URL format: redmine.example.com (no https://, no trailing slash)
# API key: Redmine → My Account → API access key (right sidebar)
# Leave REDMINE_URL blank to skip Redmine setup entirely.

REDMINE_URL=""
REDMINE_KEY=""

# ──────────────────────────────────────────────
# Context7 (library documentation MCP)
# ──────────────────────────────────────────────
# Sign up at: https://context7.com (free tier available)
# API key: https://context7.com/dashboard → API Keys
# Leave blank to skip.

CONTEXT7_KEY=""

# ──────────────────────────────────────────────
# GCS (Google Cloud Storage for interactive plans)
# ──────────────────────────────────────────────
# Bucket name for uploading HTML architecture plans.
# See docs/gcs-setup.md for full setup instructions.
# Leave blank to skip.

GCS_BUCKET=""
